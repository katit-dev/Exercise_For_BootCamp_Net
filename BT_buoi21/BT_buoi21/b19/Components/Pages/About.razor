@page "/"
@page "/about"
@layout ResumeLayout


<div style="width: 100%; height: 100%; display: flex; flex-direction: column; justify-content: center;">
    <section>
    <h1 class="display-3 fw-bold text-uppercase">
        @profile.FirstName <span style="color: #bd5d38;">@profile.LastName</span>
    </h1>

    <p class="fs-5 text-muted">
        @profile.Address · @profile.Phone ·
        <a style="color: #bd5d38; text-decoration: underline;" href="mailto:@profile.Email">@profile.Email</a>
    </p>

    <p class="mt-4 lead">
        @profile.Summary
    </p>

    <div class="social-icons">
        <a href="#"><i class="fab fa-linkedin-in"></i></a>
        <a href="#"><i class="fab fa-github"></i></a>
        <a href="#"><i class="fab fa-twitter"></i></a>
        <a href="#"><i class="fab fa-facebook-f"></i></a>
    </div>
</section>
</div>

@code {
    ProfileVM profile = new()
    {
        FirstName = "Clarence",
        LastName = "Taylor",
        Address = "3542 Berry Street · Cheyenne Wells, CO 80810",
        Phone = "(317) 585-8468",
        Email = "name@email.com",
        Summary = "I am experienced in leveraging agile frameworks to provide a robust synopsis for high level overviews. Iterative approaches to corporate strategy foster collaborative thinking to further the overall value proposition.",
        SocialLinks = new List<string> { "LinkedIn", "GitHub", "Twitter", "Facebook" }
    };
}